# Copy to backend/.env for local development. In production, set these with
# `fly secrets set KEY=value` instead of committing them.

ENVIRONMENT=development

# Postgres (local default matches docker-compose)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/app

# JWT — generate a real secret:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-only-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# First-run seed user (created only if the users table is empty)
SEED_USERNAME=admin
SEED_PASSWORD=changeme

# Dev CORS (Vite dev server). Not used in production (same-origin).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── LLM (Anthropic) ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
JARVIS_MODEL=claude-sonnet-4-20250514
JARVIS_ROUTER_MODEL=claude-haiku-4-5-20251001

# ── Email channel (dedicated Gmail + app password) ───────────────────────────
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
INGEST_POLL_SECONDS=120

# Who may command JARVIS (comma-separated). Your real inbox — NOT the bot account.
ALLOWED_SENDERS=

# ── Action safety ────────────────────────────────────────────────────────────
CONFIRM_THRESHOLD_USD=50

# ── Finance (Alpaca) — keep paper=true until the gate is proven ───────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

# ── SMS channel (Phase 1) ────────────────────────────────────────────────────
# Provider: "twilio" for real texting, "stub" for local/dev (no account).
SMS_PROVIDER=stub
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_VALIDATE_SIGNATURE=true
# Public webhook URL Twilio posts to (used for signature validation):
SMS_PUBLIC_URL=
# Whitelisted phone numbers allowed to command JARVIS (comma-separated, E.164):
ALLOWED_NUMBERS=

# ── Trading master switch ────────────────────────────────────────────────────
# Keep OFF until the dashboard has proper auth. When false, place_stock_order is
# a hard-disabled stub (no orders placed).
ENABLE_TRADING=false

# ── Memory reflector (Phase 1) ───────────────────────────────────────────────
ENABLE_REFLECTOR=true
EMBEDDING_PROVIDER=local        # "local" (offline, free) or "voyage"
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3
EMBEDDING_DIM=1024
USE_PGVECTOR=true               # uses pgvector on Postgres; ignored on SQLite
MEMORY_DEDUP_THRESHOLD=0.92
MEMORY_RECALL_K=8

# ── Job worker (Phase 1) ─────────────────────────────────────────────────────
WORKER_POLL_SECONDS=5
JOB_MAX_ATTEMPTS=3

# Mirror every SMS reply to the owner's inbox (text in -> text + email out).
SMS_EMAIL_COPY=true
OWNER_EMAIL=            # defaults to the first ALLOWED_SENDERS entry if blank

# ── Google Calendar (read-only, service account) ─────────────────────────────
# Paste the service-account JSON key as one line. Share your calendar with the
# service account's email (Reader). Leave blank to keep calendar disabled.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_CALENDAR_ID=primary
CALENDAR_TIMEZONE=America/Los_Angeles

# ── Morning briefing (Phase 2) ───────────────────────────────────────────────
BRIEFING_ENABLED=false          # true to email a daily briefing
BRIEFING_HOUR=6                 # local hour (24h)
BRIEFING_MINUTE=30

# ── Ideas repo (Phase 2) ─────────────────────────────────────────────────────
# Separate PRIVATE GitHub repo. Ideas are captured to the DB first and committed
# out-of-band, so a bad token can delay a commit but never lose a thought.
GITHUB_TOKEN=
IDEAS_REPO=mdk32366/jarvis-ideas
IDEAS_BRANCH=main

# ── Travel (Phase 2) ─────────────────────────────────────────────────────────
# Trips are learned from confirmation emails — no airline credentials, no
# scraping. These are for flight SEARCH only (research; JARVIS cannot book).
DUFFEL_API_KEY=
AMADEUS_API_KEY=

# ── Voice (Phase 1) ──────────────────────────────────────────────────────────
VOICE_ENABLED=true
VOICE_TTS_VOICE=Polly.Joanna-Neural
VOICE_PUBLIC_URL_BASE=https://jarvis-mdk.fly.dev

# ── Public compliance pages (Twilio / carrier review) ────────────────────────
# BUSINESS_NAME must match your Twilio Brand Registration exactly — reviewers
# cross-reference the landing page against the registered brand. For a sole
# proprietor this is normally your legal name.
BUSINESS_NAME=
# Published publicly. Do NOT use a personal address. Gmail plus-addressing works;
# a real domain (compliance@yourdomain.com) is better.
COMPLIANCE_EMAIL=jarvismajorus+compliance@gmail.com

# ── Owner identity ───────────────────────────────────────────────────────────
# Facts about you that never change. Without these JARVIS emails you a transcript
# after every call and STILL asks "what's your email address?" — the address was
# only reachable inside the job queue, never as knowledge she could use.
OWNER_NAME=Matthew Kelly
OWNER_EMAIL=mdk32366@gmail.com
OWNER_PHONE=+14252205779
# Home airport: lets "find me a flight to SFO" work without "from where?"
OWNER_HOME_AIRPORT=SEA
OWNER_HOME_ADDRESS=
# e.g. "Alaska MP 12345678, Delta SkyMiles 987654321"
OWNER_FREQUENT_FLYER=

# ── Google OAuth (Contacts + Tasks) ──────────────────────────────────────────
# REQUIRED for Google Contacts and Google Tasks. A service account CANNOT reach a
# consumer Google account's contacts or task list — no scope or setting makes
# that work for @gmail.com. Only OAuth can. Additive: the service account keeps
# handling Calendar.
#   python -m app.google_oauth --client-secrets client.json
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# ── Outbound calling (JARVIS rings YOU) ──────────────────────────────────────
# What turns her from an IVR into an assistant: work that won't fit inside a
# call's poll budget no longer gets demoted to an email. She says "I'll call you
# back," hangs up, does it, and rings.
#
# SAFETY: she can only ever dial a number in ALLOWED_NUMBERS. Enforced at both
# schedule time and dial time. OWNER_PHONE must be in that list.
OUTBOUND_CALLS_ENABLED=false
# She does not ring at 3am. Briefings/alerts respect this; a callback you ASKED
# for does not — you asked.
QUIET_HOURS_START=21
QUIET_HOURS_END=7
# Backstop against a bug that dials in a loop.
MAX_OUTBOUND_CALLS_PER_HOUR=6

# The morning brief as a CALL rather than an alarm you have to set.
# Needs BRIEFING_ENABLED=true and OUTBOUND_CALLS_ENABLED=true.
BRIEFING_BY_PHONE=false
BRIEFING_ENABLED=false
BRIEFING_HOUR=6
BRIEFING_MINUTE=30

# ── Owner profile (expanded) ─────────────────────────────────────────────────
# The rule: if it never changes and you've ever had to go look it up, put it here.
OWNER_HOME_ADDRESS=Stanwood, WA
OWNER_WORK_ADDRESS=Pfizer, Bothell, WA
OWNER_VEHICLE=
OWNER_BOAT=
OWNER_NOTES=
# Named places, so you can say "how long to work" instead of reciting an address.
# Format: name=address; name=address
OWNER_PLACES=work=Pfizer, Bothell WA; boat=Skyline Marina, Anacortes WA

# ── Maps: traffic + places ───────────────────────────────────────────────────
# Same Google Cloud project. Enable the Directions API and the Places API.
# This is the one you'll use every day: "what time do I need to leave?"
GOOGLE_MAPS_API_KEY=

# ── Tailscale ────────────────────────────────────────────────────────────────
# Read-only. Device status + node-key expiry (the silent killer: a key expires,
# the device drops off, and you find out when something breaks).
TAILSCALE_API_KEY=
TAILSCALE_TAILNET=

# ── Watches ──────────────────────────────────────────────────────────────────
# JARVIS acting while you're not thinking about her: check a condition on a
# schedule, and CALL YOU when it fires. Needs OUTBOUND_CALLS_ENABLED=true.
# Floor on how often a recurring watch may ring, however often the condition is
# true — a watch that calls every 5 minutes is one you'll disable.
WATCH_MIN_INTERVAL_MINUTES=60

# ── Location (the phone reports where it is) ─────────────────────────────────
# The phone PUSHES; JARVIS receives. Nothing lets a voice on a phone line reach
# into the device — that asymmetry is why this is safe to build.
#
# Tasker can't sign requests like Twilio, so a shared secret in the
# X-Jarvis-Token header IS the authentication. That makes this endpoint strictly
# stronger than the voice channel, which trusts spoofable caller ID.
# Generate one:  python -c "import secrets; print(secrets.token_urlsafe(32))"
LOCATION_TOKEN=
# A fix older than this is treated as UNKNOWN, not trusted. A three-hour-old
# position routes you from a coffee shop you left at breakfast, with total
# confidence. Falling back to home is honest; guessing is not.
LOCATION_MAX_AGE_MINUTES=30
LOCATION_KEEP_PINGS=200
