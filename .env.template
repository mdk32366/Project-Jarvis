# Copy to backend/.env for local development. In production, set these with
# `fly secrets set KEY=value` instead of committing them.

ENVIRONMENT=development

# Postgres (local default matches docker-compose)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/app

# JWT — generate a real secret:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-only-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# First-run seed user (created only if the users table is empty)
SEED_USERNAME=admin
SEED_PASSWORD=changeme

# Dev CORS (Vite dev server). Not used in production (same-origin).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── LLM (Anthropic) ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
JARVIS_MODEL=claude-sonnet-4-20250514
JARVIS_ROUTER_MODEL=claude-haiku-4-5-20251001

# ── Email channel (dedicated Gmail + app password) ───────────────────────────
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
INGEST_POLL_SECONDS=120

# Who may command JARVIS (comma-separated). Your real inbox — NOT the bot account.
ALLOWED_SENDERS=

# ── Action safety ────────────────────────────────────────────────────────────
CONFIRM_THRESHOLD_USD=50

# ── Finance (Alpaca) — keep paper=true until the gate is proven ───────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
