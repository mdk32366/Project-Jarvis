# Copy to backend/.env for local development. In production, set these with
# `fly secrets set KEY=value` instead of committing them.

ENVIRONMENT=development

# Postgres (local default matches docker-compose)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/app

# JWT — generate a real secret:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-only-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# First-run seed user (created only if the users table is empty)
SEED_USERNAME=admin
SEED_PASSWORD=changeme

# Dev CORS (Vite dev server). Not used in production (same-origin).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── LLM (Anthropic) ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
JARVIS_MODEL=claude-sonnet-4-20250514
JARVIS_ROUTER_MODEL=claude-haiku-4-5-20251001

# ── Email channel (dedicated Gmail + app password) ───────────────────────────
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
INGEST_POLL_SECONDS=120

# Who may command JARVIS (comma-separated). Your real inbox — NOT the bot account.
ALLOWED_SENDERS=

# ── Action safety ────────────────────────────────────────────────────────────
CONFIRM_THRESHOLD_USD=50

# ── Finance (Alpaca) — keep paper=true until the gate is proven ───────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

# ── SMS channel (Phase 1) ────────────────────────────────────────────────────
# Provider: "twilio" for real texting, "stub" for local/dev (no account).
SMS_PROVIDER=stub
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_VALIDATE_SIGNATURE=true
# Public webhook URL Twilio posts to (used for signature validation):
SMS_PUBLIC_URL=
# Whitelisted phone numbers allowed to command JARVIS (comma-separated, E.164):
ALLOWED_NUMBERS=

# ── Trading master switch ────────────────────────────────────────────────────
# Keep OFF until the dashboard has proper auth. When false, place_stock_order is
# a hard-disabled stub (no orders placed).
ENABLE_TRADING=false

# ── Memory reflector (Phase 1) ───────────────────────────────────────────────
ENABLE_REFLECTOR=true
EMBEDDING_PROVIDER=local        # "local" (offline, free) or "voyage"
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3
EMBEDDING_DIM=1024
USE_PGVECTOR=true               # uses pgvector on Postgres; ignored on SQLite
MEMORY_DEDUP_THRESHOLD=0.92
MEMORY_RECALL_K=8

# ── Job worker (Phase 1) ─────────────────────────────────────────────────────
WORKER_POLL_SECONDS=5
JOB_MAX_ATTEMPTS=3

# Mirror every SMS reply to the owner's inbox (text in -> text + email out).
SMS_EMAIL_COPY=true
OWNER_EMAIL=            # defaults to the first ALLOWED_SENDERS entry if blank

# ── Google Calendar (read-only, service account) ─────────────────────────────
# Paste the service-account JSON key as one line. Share your calendar with the
# service account's email (Reader). Leave blank to keep calendar disabled.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_CALENDAR_ID=primary
CALENDAR_TIMEZONE=America/Los_Angeles

# ── Morning briefing (Phase 2) ───────────────────────────────────────────────
BRIEFING_ENABLED=false          # true to email a daily briefing
BRIEFING_HOUR=6                 # local hour (24h)
BRIEFING_MINUTE=30

# ── Ideas repo (Phase 2) ─────────────────────────────────────────────────────
# Separate PRIVATE GitHub repo. Ideas are captured to the DB first and committed
# out-of-band, so a bad token can delay a commit but never lose a thought.
GITHUB_TOKEN=
IDEAS_REPO=mdk32366/jarvis-ideas
IDEAS_BRANCH=main

# ── Travel (Phase 2) ─────────────────────────────────────────────────────────
# Trips are learned from confirmation emails — no airline credentials, no
# scraping. These are for flight SEARCH only (research; JARVIS cannot book).
DUFFEL_API_KEY=
AMADEUS_API_KEY=

# ── Voice (Phase 1) ──────────────────────────────────────────────────────────
VOICE_ENABLED=true
VOICE_TTS_VOICE=Polly.Joanna-Neural
VOICE_PUBLIC_URL_BASE=https://jarvis-mdk.fly.dev

# ── Public compliance pages (Twilio / carrier review) ────────────────────────
# BUSINESS_NAME must match your Twilio Brand Registration exactly — reviewers
# cross-reference the landing page against the registered brand. For a sole
# proprietor this is normally your legal name.
BUSINESS_NAME=
# Published publicly. Do NOT use a personal address. Gmail plus-addressing works;
# a real domain (compliance@yourdomain.com) is better.
COMPLIANCE_EMAIL=jarvismajorus+compliance@gmail.com
